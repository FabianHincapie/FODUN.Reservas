@model FODUN.Web.ViewModels.DisponibilidadViewModel
@{
    ViewData["Title"] = "Detalle Sede";
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>FODUN - @Model.Sede?.Nombre</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        body {
            background-color: #f5f5f5;
        }

        .header-fodun {
            background-color: #8B0000;
            color: white;
            padding: 15px 30px;
        }

        .navbar-fodun {
            background-color: #e0e0e0;
            border-bottom: 2px solid #8B0000;
        }

            .navbar-fodun .nav-link {
                color: #333;
                font-weight: 500;
            }

                .navbar-fodun .nav-link:hover {
                    color: #8B0000;
                }

        .btn-fodun {
            background-color: #8B0000;
            color: white;
            border: none;
            border-radius: 0;
        }

            .btn-fodun:hover {
                background-color: #6B0000;
                color: white;
            }

        .table thead {
            background-color: #8B0000;
            color: white;
        }

        .tab-fodun {
            background-color: #8B0000;
            color: white;
            padding: 8px 20px;
            font-weight: bold;
        }

        .section-title {
            color: #8B0000;
            font-weight: bold;
            border-bottom: 2px solid #8B0000;
            padding-bottom: 5px;
        }

        .total-value {
            color: #8B0000;
            font-size: 1.5rem;
            font-weight: bold;
        }
    </style>
</head>
<body>
    <div class="header-fodun">
        <h1 class="h3 mb-0">SISTEMA DE RESERVAS</h1>
        <small>Sedes Recreativas y Apartamentos</small>
    </div>

    <nav class="navbar-fodun px-4 py-2 d-flex justify-content-between align-items-center">
        <div class="d-flex gap-3">
            <a asp-controller="Sedes" asp-action="Index" class="nav-link">Sedes Recreativas y Apartamentos</a>
            <a asp-controller="Reservas" asp-action="MisReservas" class="nav-link">Mis Reservas</a>
            <a asp-controller="Account" asp-action="Logout" class="nav-link">Cerrar Sesión</a>
        </div>
        <div style="color:#555;font-size:0.9rem;">
            👤 Bienvenido, @Context.Session.GetString("NombreUsuario")
        </div>
    </nav>

    <div class="container-fluid mt-3 px-4">
        <h4 class="text-danger fw-bold">Sedes Recreativas y Apartamentos</h4>

        <div class="card mt-2">
            <div class="card-header p-0 d-flex">
                <a asp-controller="Sedes" asp-action="Index" class="nav-link px-3 d-flex align-items-center">
                    Sedes Recreativas y Apartamentos
                </a>
                <span class="tab-fodun">Seleccione sus Fechas</span>
            </div>
            <div class="card-body">
                <div class="row">
                    <!-- Panel izquierdo: Fechas y Total -->
                    <div class="col-md-3">
                        <h5 class="section-title">Mis Fechas</h5>
                        <form asp-action="Detalle" method="get" id="formFechas">
                            <input type="hidden" name="id" value="@Model.Sede?.SedeId" />

                            <div class="mb-2">
                                <label class="form-label fw-bold small">Fecha de Llegada:</label>
                                <input type="date" name="fechaLlegada" id="fechaLlegada"
                                       class="form-control form-control-sm"
                                       value="@(Model.FechaLlegada != default(DateTime) ? Model.FechaLlegada.ToString("yyyy-MM-dd") : "")" />

                            </div>
                            <div class="mb-2">
                                <label class="form-label fw-bold small">Fecha de Salida:</label>
                                <input type="date" name="fechaSalida" id="fechaSalida"
                                       class="form-control form-control-sm"
                                       value="@(Model.FechaSalida != default(DateTime) ? Model.FechaSalida.ToString("yyyy-MM-dd") : "")" />
                            </div>
                            <div class="mb-2">
                                <label class="form-label fw-bold small">Noches:</label>
                                <input type="text" id="noches" class="form-control form-control-sm" readonly
                                       value="@(Model.FechaLlegada != default ? (Model.FechaSalida - Model.FechaLlegada).Days.ToString() : "")"
                                       style="background-color:#e9ecef; cursor:not-allowed;" />

                            </div>
                            <div class="mb-2">
                                <label class="form-label fw-bold small">Personas:</label>
                                <input type="number" name="numPersonas" class="form-control form-control-sm"
                                       value="@(Model.NumPersonas > 0 ? Model.NumPersonas.ToString() : "")"
                                       min="1" max="20" placeholder="Número de personas" />
                            </div>
                            <div class="mb-2">
                                <input type="checkbox" name="servicioLavanderia" id="lavanderia" value="true" />
                                <label for="lavanderia" class="small">Servicio de Lavandería</label>
                            </div>
                            <div class="mt-2">
                                <button type="submit" class="btn btn-fodun w-100">Buscar Disponibilidad</button>
                            </div>
                        </form>

                        <hr />
                        <h5 class="section-title">Total Reserva</h5>
                        <div class="mb-1">
                            <small class="fw-bold">Habitaciones:</small>
                            <span id="txtHabitaciones"></span>
                        </div>
                        <div class="mb-1">
                            <small class="fw-bold">Días Ordinarios:</small>
                            <span id="txtDiasOrdinarios"></span>
                        </div>
                        <div class="mb-1">
                            <small class="fw-bold">Días Especiales:</small>
                            <span id="txtDiasEspeciales"></span>
                        </div>
                        <div class="mb-1">
                            <small class="fw-bold">Lavandería:</small>
                            <span id="txtLavanderia"></span>
                        </div>
                        <div class="mt-2">
                            <span class="fw-bold">Valor Total:</span>
                            <span class="total-value" id="txtValorTotal">$000.000</span>
                        </div>
                        <div class="mt-3">
                            <button class="btn btn-fodun w-100" onclick="confirmarReserva()">Reservar</button>
                        </div>
                    </div>

                    <!-- Panel central: Imagen y descripción -->
                    <div class="col-md-5">
                        <h5 class="section-title">@Model.Sede?.Nombre</h5>
                        <img src="~/images/sedes/@(Model.Sede?.ImagenPrincipal ?? "default.png")"
                             class="img-fluid mb-2" style="max-height:200px;object-fit:cover;width:100%;" />
                        <p class="small">@Model.Sede?.Descripcion</p>
                    </div>

                    <!-- Panel derecho: Info sede -->
                    <div class="col-md-4">
                        <div class="bg-light p-3" style="max-height:300px;overflow-y:auto;font-size:0.85rem;">
                            <strong>Capacidad total: hasta @Model.Sede?.CapacidadTotal personas</strong>
                            <hr />
                            @if (Model.Sede?.Alojamientos != null)
                            {
                                foreach (var aloj in Model.Sede.Alojamientos)
                                {
                                    <p><strong>@aloj.Nombre:</strong> @aloj.Descripcion</p>
                                }
                            }
                        </div>
                    </div>
                </div>

                <!-- Tabla de alojamientos -->
                @if (Model.Alojamientos.Any())
                {
                    <div class="mt-4">
                        <h5 class="section-title">Habitaciones / Alojamientos</h5>
                        <table class="table table-bordered table-sm mt-2">
                            <thead>
                                <tr>
                                    <th>Detalles</th>
                                    <th>Habitación / Alojamiento</th>
                                    <th>Capacidad</th>
                                    <th>Tarifa día Ordinario</th>
                                    <th>Tarifa día Especial</th>
                                    <th>Disponibilidad</th>
                                    <th>Reservar</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.Alojamientos)
                                {
                                    <tr class="@(!item.Disponible ? "table-secondary text-muted" : "")">
                                        <td class="text-center">
                                            <button class="btn btn-sm btn-outline-secondary"
                                                    onclick="verDetalle(@item.Alojamiento!.AlojamientoId)">
                                                🔍
                                            </button>
                                        </td>
                                        <td>@item.Alojamiento?.Numero</td>
                                        <td>@item.Alojamiento?.CapacidadMax</td>
                                        <td>@item.TarifaOrdinaria.ToString("C0")</td>
                                        <td>@item.TarifaEspecial.ToString("C0")</td>
                                        <td class="text-center">
                                            @if (item.Disponible)
                                            {
                                                <span class="text-success">✔</span>
                                            }
                                            else
                                            {
                                                <span class="text-danger">✘</span>
                                            }
                                        </td>
                                        <td class="text-center">
                                            @if (item.Disponible)
                                            {
                                                <input type="checkbox" class="chk-reserva"
                                                       value="@item.Alojamiento?.AlojamientoId"
                                                       data-tarifa="@item.TarifaOrdinaria"
                                                       onchange="calcularTotal()" />
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Modal Confirmar Reserva -->
    <div class="modal fade" id="modalConfirmar" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title">Confirmación Reserva</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="row">
                        <div class="col-6">
                            <h6 class="text-danger">Mis Fechas</h6>
                            <p><strong>Fecha de Llegada:</strong> @Model.FechaLlegada.ToString("dd/MM/yyyy")</p>
                            <p><strong>Fecha de Salida:</strong> @Model.FechaSalida.ToString("dd/MM/yyyy")</p>
                            <p><strong>Noches:</strong> @((Model.FechaSalida - Model.FechaLlegada).Days)</p>
                            <p><strong>Personas:</strong> @Model.NumPersonas</p>
                        </div>
                        <div class="col-6">
                            <h6 class="text-danger">Total Reserva</h6>
                            <p><strong>Habitaciones:</strong> <span id="modalHabitaciones"></span></p>
                            <p><strong>Valor Total:</strong> <span id="modalValorTotal" class="text-danger fw-bold"></span></p>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <form asp-controller="Reservas" asp-action="Crear" method="post" id="formReserva">
                        <input type="hidden" name="SedeId" value="@Model.Sede?.SedeId" />
                        <input type="hidden" name="FechaLlegada" value="@Model.FechaLlegada.ToString("yyyy-MM-dd")" />
                        <input type="hidden" name="FechaSalida" value="@Model.FechaSalida.ToString("yyyy-MM-dd")" />
                        <input type="hidden" name="NumPersonas" value="@Model.NumPersonas" />
                        <input type="hidden" name="AlojamientoId" id="hdnAlojamientoId" />
                        <input type="hidden" name="NumHabitaciones" id="hdnNumHabitaciones" />
                        <button type="submit" class="btn btn-fodun">Confirmar</button>
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function calcularTotal() {
            var checkboxes = document.querySelectorAll('.chk-reserva:checked');
            var total = 0;
            var numHabitaciones = checkboxes.length;
            var noches = @(Model.FechaLlegada != default(DateTime) ? (Model.FechaSalida - Model.FechaLlegada).Days : 0);

            checkboxes.forEach(function(chk) {
                total += parseFloat(chk.dataset.tarifa);
            });

            document.getElementById('txtHabitaciones').innerText = numHabitaciones;
            document.getElementById('txtDiasOrdinarios').innerText = noches;
            document.getElementById('txtValorTotal').innerText = '$' + total.toLocaleString('es-CO');
        }

        function confirmarReserva() {
            var checkboxes = document.querySelectorAll('.chk-reserva:checked');
            if (checkboxes.length === 0) {
                alert('Por favor seleccione al menos un alojamiento.');
                return;
            }

            var alojamientoId = checkboxes[0].value;
            var numHabitaciones = checkboxes.length;
            var total = 0;

            checkboxes.forEach(function(chk) {
                total += parseFloat(chk.dataset.tarifa);
            });

            document.getElementById('hdnAlojamientoId').value = alojamientoId;
            document.getElementById('hdnNumHabitaciones').value = numHabitaciones;
            document.getElementById('modalHabitaciones').innerText = numHabitaciones;
            document.getElementById('modalValorTotal').innerText = '$' + total.toLocaleString('es-CO');

            var modal = new bootstrap.Modal(document.getElementById('modalConfirmar'));
            modal.show();
        }

        function verDetalle(alojamientoId) {
            alert('Detalle del alojamiento: ' + alojamientoId);
        }
    </script>
</body>
</html>