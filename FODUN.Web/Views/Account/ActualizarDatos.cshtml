@model FODUN.Web.ViewModels.ActualizarDatosViewModel
@{
    ViewData["Title"] = "Actualizar Datos";
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>FODUN - Actualizar Datos</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        body {
            background-color: #f5f5f5;
        }

        .header-fodun {
            background-color: #8B0000;
            color: white;
            padding: 15px 30px;
        }

        .navbar-fodun {
            background-color: #e0e0e0;
            border-bottom: 2px solid #8B0000;
        }

            .navbar-fodun .nav-link {
                color: #333;
                font-weight: 500;
            }

                .navbar-fodun .nav-link:hover {
                    color: #8B0000;
                }

        .btn-fodun {
            background-color: #8B0000;
            color: white;
            border: none;
        }

            .btn-fodun:hover {
                background-color: #6B0000;
                color: white;
            }

        .card-header-fodun {
            background-color: #8B0000;
            color: white;
        }
    </style>
</head>
<body>
    <div class="header-fodun">
        <h1 class="h3 mb-0">SISTEMA DE RESERVAS</h1>
        <small>Sedes Recreativas y Apartamentos</small>
    </div>

    <nav class="navbar-fodun px-4 py-2 d-flex justify-content-between align-items-center">
        <div class="d-flex gap-3">
            <a asp-controller="Sedes" asp-action="Index" class="nav-link">Sedes Recreativas y Apartamentos</a>
            <a asp-controller="Reservas" asp-action="MisReservas" class="nav-link">Mis Reservas</a>
            <a asp-controller="Account" asp-action="ActualizarDatos" class="nav-link active">Actualizar Datos</a>
            <a asp-controller="Account" asp-action="Logout" class="nav-link">Cerrar Sesión</a>
        </div>
        <div style="color:#555;font-size:0.9rem;">
            👤 Bienvenido, @Context.Session.GetString("NombreUsuario")
        </div>
    </nav>

    <div class="container mt-4 mb-5">
        <div class="row justify-content-center">
            <div class="col-md-10">

                @if (TempData["Mensaje"] != null)
                {
                    <div class="alert alert-success">@TempData["Mensaje"]</div>
                }

                <div class="card shadow">
                    <div class="card-header card-header-fodun">
                        <h5 class="mb-0">Actualizar Datos</h5>
                    </div>
                    <div class="card-body p-4">
                        <form asp-action="ActualizarDatos" method="post">
                            <div asp-validation-summary="All" class="text-danger mb-3"></div>

                            <div class="row">
                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label asp-for="NroDocumento" class="form-label fw-bold"></label>
                                        <input asp-for="NroDocumento" class="form-control" readonly />
                                    </div>
                                    <div class="mb-3">
                                        <label asp-for="NombreCompleto" class="form-label fw-bold"></label>
                                        <input asp-for="NombreCompleto" class="form-control" />
                                        <span asp-validation-for="NombreCompleto" class="text-danger"></span>
                                    </div>
                                    <div class="mb-3">
                                        <label asp-for="FechaNacimiento" class="form-label fw-bold"></label>
                                        <input asp-for="FechaNacimiento" class="form-control" type="date" />
                                    </div>
                                    <div class="mb-3">
                                        <label asp-for="Celular" class="form-label fw-bold"></label>
                                        <input asp-for="Celular" class="form-control" />
                                    </div>
                                    <div class="mb-3">
                                        <label asp-for="Email" class="form-label fw-bold"></label>
                                        <input asp-for="Email" class="form-control" />
                                        <span asp-validation-for="Email" class="text-danger"></span>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label asp-for="Departamento" class="form-label fw-bold"></label>
                                        <input asp-for="Departamento" class="form-control" />
                                    </div>
                                    <div class="mb-3">
                                        <label asp-for="Municipio" class="form-label fw-bold"></label>
                                        <input asp-for="Municipio" class="form-control" />
                                    </div>
                                    <div class="mb-3">
                                        <label asp-for="Barrio" class="form-label fw-bold"></label>
                                        <input asp-for="Barrio" class="form-control" />
                                    </div>
                                    <div class="mb-3">
                                        <label asp-for="DireccionResidencia" class="form-label fw-bold"></label>
                                        <input asp-for="DireccionResidencia" class="form-control" />
                                    </div>
                                    <div class="mb-3">
                                        <label asp-for="TelefonoResidencia" class="form-label fw-bold"></label>
                                        <input asp-for="TelefonoResidencia" class="form-control" />
                                    </div>
                                </div>
                            </div>

                            <div class="d-flex justify-content-center gap-3 mt-3">
                                <button type="submit" class="btn btn-fodun px-4">Guardar Cambios</button>
                                <a asp-controller="Sedes" asp-action="Index" class="btn btn-secondary px-4">Cancelar</a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <partial name="_ValidationScriptsPartial" />
</body>
</html>