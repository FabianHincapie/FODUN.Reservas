@model IEnumerable<FODUN.Entities.Models.Sede>
@{
    ViewData["Title"] = "Sedes Recreativas y Apartamentos";
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>FODUN - Sistema de Reservas</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        body {
            background-color: #f5f5f5;
        }

        .header-fodun {
            background-color: #8B0000;
            color: white;
            padding: 15px 30px;
        }

        .navbar-fodun {
            background-color: #e0e0e0;
            border-bottom: 2px solid #8B0000;
        }

            .navbar-fodun .nav-link {
                color: #333;
                font-weight: 500;
            }

                .navbar-fodun .nav-link:hover,
                .navbar-fodun .nav-link.active {
                    color: #8B0000;
                    border-bottom: 2px solid #8B0000;
                }

        .btn-fodun {
            background-color: #8B0000;
            color: white;
            border: none;
            border-radius: 0;
        }

            .btn-fodun:hover {
                background-color: #6B0000;
                color: white;
            }

        .table thead {
            background-color: #8B0000;
            color: white;
        }

        .tab-fodun {
            background-color: #8B0000;
            color: white;
            padding: 8px 20px;
            font-weight: bold;
        }

        .bienvenido {
            color: #555;
            font-size: 0.9rem;
        }
    </style>
</head>
<body>
    <!-- Header -->
    <div class="header-fodun d-flex justify-content-between align-items-center">
        <div>
            <h1 class="h3 mb-0">SISTEMA DE RESERVAS</h1>
            <small>Sedes Recreativas y Apartamentos</small>
        </div>
    </div>

    <!-- Navbar -->
    <nav class="navbar-fodun px-4 py-2 d-flex justify-content-between align-items-center">
        <div class="d-flex gap-3">
            <a asp-controller="Sedes" asp-action="Index" class="nav-link active">Sedes Recreativas y Apartamentos</a>
            <a asp-controller="Reservas" asp-action="MisReservas" class="nav-link">Mis Reservas</a>
            <a asp-controller="Account" asp-action="ActualizarDatos" class="nav-link">Actualizar Datos</a>
            <a asp-controller="Account" asp-action="Logout" class="nav-link">Cerrar Sesión</a>
        </div>
        <div class="bienvenido">
            👤 Bienvenido, @Context.Session.GetString("NombreUsuario")
        </div>
    </nav>

    <!-- Contenido -->
    <div class="container-fluid mt-4 px-4">
        <h4 class="text-danger fw-bold">Sedes Recreativas y Apartamentos</h4>

        <div class="card mt-3">
            <div class="card-header p-0 d-flex">
                <span class="tab-fodun">Sedes Recreativas y Apartamentos</span>
                <span class="nav-link px-3 d-flex align-items-center text-muted">
                    Seleccione sus Fechas
                </span>
            </div>
            <div class="card-body p-0">
                <table class="table table-bordered table-hover mb-0">
                    <thead>
                        <tr>
                            <th style="width:80px"></th>
                            <th>Nombre</th>
                            <th>Descripción</th>
                            <th>Tipo</th>
                            <th>Ubicación</th>
                            <th>Seleccionar</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var sede in Model)
                        {
                            <tr>
                                <td class="text-center">
                                    <img src="~/images/sedes/@(sede.ImagenPrincipal ?? "default.jpg")"
                                         onerror="this.src='/images/sedes/default.png'"
                                         width="70" height="50"
                                         style="object-fit:cover;" />
                                </td>
                                <td class="fw-bold">@sede.Nombre</td>
                                <td>
                                    <small>@sede.Descripcion</small>
                                </td>
                                <td>@sede.TipoSede?.Nombre</td>
                                <td>@sede.Ciudad</td>
                                <td>
                                    <a asp-action="Detalle"
                                       asp-route-id="@sede.SedeId"
                                       class="btn btn-fodun btn-sm">
                                        Seleccionar
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <footer class="text-center text-muted mt-5 py-3" style="font-size:0.8rem; border-top:1px solid #ddd;">
        FODUN - Fondo de Docentes Universidad Nacional - Derechos Reservados © 2026
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>