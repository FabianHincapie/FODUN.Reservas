@model FODUN.Web.ViewModels.RegistroViewModel
@{
    ViewData["Title"] = "Registro de Usuario";
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>FODUN - Registro de Usuario</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        body {
            background-color: #f5f5f5;
        }

        .login-header {
            background-color: #8B0000;
            color: white;
            padding: 15px 30px;
        }

            .login-header h1 {
                font-size: 1.8rem;
                margin: 0;
            }

            .login-header p {
                margin: 0;
                font-size: 0.9rem;
            }

        .btn-fodun {
            background-color: #8B0000;
            color: white;
            border: none;
        }

            .btn-fodun:hover {
                background-color: #6B0000;
                color: white;
            }

        .card-header-fodun {
            background-color: #8B0000;
            color: white;
        }
    </style>
</head>
<body>
    <div class="login-header d-flex align-items-center gap-3">
        <div>
            <h1>SISTEMA DE RESERVAS</h1>
            <p>Sedes Recreativas y Apartamentos</p>
        </div>
    </div>

    <div class="container mt-4 mb-5">
        <div class="row justify-content-center">
            <div class="col-md-10">
                <div class="card shadow">
                    <div class="card-header card-header-fodun">
                        <h5 class="mb-0">Registro Nuevo Usuario</h5>
                    </div>
                    <div class="card-body p-4">
                        <form asp-action="Registro" method="post">
                            <div asp-validation-summary="All" class="text-danger mb-3"></div>

                            <div class="row">
                                <!-- Columna izquierda -->
                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label asp-for="NroDocumento" class="form-label fw-bold"></label>
                                        <input asp-for="NroDocumento" class="form-control" />
                                        <span asp-validation-for="NroDocumento" class="text-danger"></span>
                                    </div>
                                    <div class="mb-3">
                                        <label asp-for="NombreCompleto" class="form-label fw-bold"></label>
                                        <input asp-for="NombreCompleto" class="form-control" />
                                        <span asp-validation-for="NombreCompleto" class="text-danger"></span>
                                    </div>
                                    <div class="mb-3">
                                        <label asp-for="FechaNacimiento" class="form-label fw-bold"></label>
                                        <input asp-for="FechaNacimiento" class="form-control" type="date" />
                                    </div>
                                    <div class="mb-3">
                                        <label asp-for="Celular" class="form-label fw-bold"></label>
                                        <input asp-for="Celular" class="form-control" />
                                    </div>
                                    <div class="mb-3">
                                        <label asp-for="Email" class="form-label fw-bold"></label>
                                        <input asp-for="Email" class="form-control" />
                                        <span asp-validation-for="Email" class="text-danger"></span>
                                    </div>
                                    <div class="mb-3">
                                        <label asp-for="Departamento" class="form-label fw-bold"></label>
                                        <input asp-for="Departamento" class="form-control" />
                                        <span asp-validation-for="Departamento" class="text-danger"></span>
                                    </div>
                                    <div class="mb-3">
                                        <label asp-for="Municipio" class="form-label fw-bold"></label>
                                        <input asp-for="Municipio" class="form-control" />
                                        <span asp-validation-for="Municipio" class="text-danger"></span>
                                    </div>
                                    <div class="mb-3">
                                        <label asp-for="Barrio" class="form-label fw-bold"></label>
                                        <input asp-for="Barrio" class="form-control" />
                                        <span asp-validation-for="Barrio" class="text-danger"></span>
                                    </div>
                                    <div class="mb-3">
                                        <label asp-for="DireccionResidencia" class="form-label fw-bold"></label>
                                        <input asp-for="DireccionResidencia" class="form-control" />
                                        <span asp-validation-for="DireccionResidencia" class="text-danger"></span>
                                    </div>
                                    <div class="mb-3">
                                        <label asp-for="TelefonoResidencia" class="form-label fw-bold"></label>
                                        <input asp-for="TelefonoResidencia" class="form-control" />
                                    </div>
                                </div>

                                <!-- Columna derecha -->
                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label asp-for="PreguntaSecreta" class="form-label fw-bold"></label>
                                        <select asp-for="PreguntaSecreta" class="form-select">
                                            <option value="">SELECCIONE UNA PREGUNTA...</option>
                                            <option>¿Cuál es el nombre de tu mascota?</option>
                                            <option>¿Cuál es el nombre de tu madre?</option>
                                            <option>¿En qué ciudad naciste?</option>
                                            <option>¿Cuál es tu equipo de fútbol favorito?</option>
                                            <option>¿Cuál fue el nombre de tu primera escuela?</option>
                                        </select>
                                    </div>
                                    <div class="mb-3">
                                        <label asp-for="RespuestaSecreta" class="form-label fw-bold"></label>
                                        <input asp-for="RespuestaSecreta" class="form-control" />
                                        <small class="text-muted">Esta respuesta se utilizará para la recuperación de la clave</small>
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label fw-bold">¿Autoriza el envío de información al correo?</label>
                                        <div>
                                            <div class="form-check form-check-inline">
                                                <input class="form-check-input" type="radio" asp-for="AutorizaCorreo" value="true" checked />
                                                <label class="form-check-label">Sí</label>
                                            </div>
                                            <div class="form-check form-check-inline">
                                                <input class="form-check-input" type="radio" asp-for="AutorizaCorreo" value="false" />
                                                <label class="form-check-label">No</label>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label fw-bold">¿Autoriza el envío de información al celular?</label>
                                        <div>
                                            <div class="form-check form-check-inline">
                                                <input class="form-check-input" type="radio" asp-for="AutorizaCelular" value="true" checked />
                                                <label class="form-check-label">Sí</label>
                                            </div>
                                            <div class="form-check form-check-inline">
                                                <input class="form-check-input" type="radio" asp-for="AutorizaCelular" value="false" />
                                                <label class="form-check-label">No</label>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="mb-3">
                                        <label asp-for="Password" class="form-label fw-bold"></label>
                                        <input asp-for="Password" class="form-control" />
                                        <small class="text-muted">La clave debe contener mínimo 4 caracteres</small>
                                        <span asp-validation-for="Password" class="text-danger"></span>
                                    </div>
                                    <div class="mb-3">
                                        <label asp-for="ConfirmarPassword" class="form-label fw-bold"></label>
                                        <input asp-for="ConfirmarPassword" class="form-control" />
                                        <span asp-validation-for="ConfirmarPassword" class="text-danger"></span>
                                    </div>
                                </div>
                            </div>

                            <div class="d-flex justify-content-center gap-3 mt-3">
                                <button type="submit" class="btn btn-fodun px-4">
                                    <i class="bi bi-send"></i> Enviar
                                </button>
                                <a asp-action="Login" class="btn btn-danger px-4">Cancelar</a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <partial name="_ValidationScriptsPartial" />
</body>
</html>