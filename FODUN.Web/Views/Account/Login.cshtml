@model FODUN.Web.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Iniciar Sesión";
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>FODUN - Sistema de Reservas</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        body { background-color: #f5f5f5; }
        .login-header {
            background-color: #8B0000;
            color: white;
            padding: 15px 30px;
        }
        .login-header h1 { font-size: 1.8rem; margin: 0; }
        .login-header p  { margin: 0; font-size: 0.9rem; }
        .btn-fodun {
            background-color: #8B0000;
            color: white;
            border: none;
        }
        .btn-fodun:hover { background-color: #6B0000; color: white; }
        .card { border-radius: 0; }
    </style>
</head>
<body>
    <div class="login-header d-flex align-items-center gap-3">
        <div>
            <h1>SISTEMA DE RESERVAS</h1>
            <p>Sedes Recreativas y Apartamentos</p>
        </div>
    </div>

    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-md-5">

                @if (TempData["Mensaje"] != null)
                {
                    <div class="alert alert-success">@TempData["Mensaje"]</div>
                }
                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger">@TempData["Error"]</div>
                }

                <div class="card shadow">
                    <div class="card-header bg-dark text-white">
                        <h5 class="mb-0">Ingreso Sistema de Reservas</h5>
                    </div>
                    <div class="card-body p-4">
                        <form asp-action="Login" method="post">
                            <input type="hidden" asp-for="ReturnUrl" />
                            <div asp-validation-summary="All" class="text-danger mb-3"></div>

                            <div class="mb-3">
                                <label asp-for="NroDocumento" class="form-label fw-bold"></label>
                                <input asp-for="NroDocumento" class="form-control" placeholder="Ingrese su número de documento" />
                                <span asp-validation-for="NroDocumento" class="text-danger"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Password" class="form-label fw-bold"></label>
                                <input asp-for="Password" class="form-control" placeholder="Ingrese su contraseña" />
                                <span asp-validation-for="Password" class="text-danger"></span>
                            </div>

                            <div class="d-grid mb-3">
                                <button type="submit" class="btn btn-fodun btn-lg">Aceptar</button>
                            </div>

                            <div class="text-center">
                                <a asp-action="RecuperarPassword" class="text-danger">¿Olvidó su contraseña?</a>
                            </div>
                        </form>
                    </div>
                </div>

                <div class="mt-3">
                    <a asp-action="Registro" class="btn btn-fodun w-100 py-3">
                        ¿Usuario Nuevo? <strong>REGÍSTRESE AQUÍ</strong>
                    </a>
                </div>

            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <partial name="_ValidationScriptsPartial" />
</body>
</html>