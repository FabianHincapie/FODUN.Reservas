@model FODUN.Web.ViewModels.RestablecerPasswordViewModel
@{
    ViewData["Title"] = "Restablecer Contraseña";
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>FODUN - Restablecer Contraseña</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        body {
            background-color: #f5f5f5;
        }

        .login-header {
            background-color: #8B0000;
            color: white;
            padding: 15px 30px;
        }

        .btn-fodun {
            background-color: #8B0000;
            color: white;
            border: none;
        }

            .btn-fodun:hover {
                background-color: #6B0000;
                color: white;
            }
    </style>
</head>
<body>
    <div class="login-header">
        <h1>SISTEMA DE RESERVAS</h1>
        <p>Sedes Recreativas y Apartamentos</p>
    </div>

    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-md-5">
                <div class="card shadow">
                    <div class="card-header bg-dark text-white">
                        <h5 class="mb-0">Restablecer Contraseña</h5>
                    </div>
                    <div class="card-body p-4">
                        <form asp-action="RestablecerPassword" method="post">
                            <div asp-validation-summary="All" class="text-danger mb-3"></div>
                            <input type="hidden" asp-for="Token" />

                            <div class="mb-3">
                                <label asp-for="NuevaPassword" class="form-label fw-bold"></label>
                                <input asp-for="NuevaPassword" class="form-control" />
                                <span asp-validation-for="NuevaPassword" class="text-danger"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="ConfirmarPassword" class="form-label fw-bold"></label>
                                <input asp-for="ConfirmarPassword" class="form-control" />
                                <span asp-validation-for="ConfirmarPassword" class="text-danger"></span>
                            </div>

                            <div class="d-grid mb-3">
                                <button type="submit" class="btn btn-fodun btn-lg">Restablecer Contraseña</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <partial name="_ValidationScriptsPartial" />
</body>
</html>